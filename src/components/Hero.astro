---
import type { PlatformDownload } from "../data/downloadManifest";
import { sitePath } from "../lib/urls";
import Logo from "./Logo.astro";
import PlatformBadge from "./PlatformBadge.astro";
import PrimaryButton from "./PrimaryButton.astro";
import SecondaryButton from "./SecondaryButton.astro";

interface Props { macos: PlatformDownload; windows: PlatformDownload }
const { macos, windows } = Astro.props;
---
<section class="hero">
  <div class="shell hero-grid">
    <div class="hero-copy">
      <div class="hero-brand"><Logo size={52} compact={false} /><span><strong>纤云叙</strong><small>XianYun AI Voice Input</small></span></div>
      <p class="eyebrow">中文办公 · AI 语音输入</p>
      <h1>说出来，<em>落成文。</em></h1>
      <p class="hero-lead">为中文办公而做的 AI 语音输入工具。<br />像平时一样说，它会整理好，再写进你正在使用的应用。</p>
      <div class="button-row hero-actions">
        <PrimaryButton href={sitePath("/download/")}>选择平台下载</PrimaryButton>
        <SecondaryButton href={sitePath("/install/")}>查看安装说明</SecondaryButton>
      </div>
      <div class="hero-badges" aria-label="当前发布状态">
        <PlatformBadge tone={macos.status === "available" ? "brand" : "neutral"}>macOS Apple Silicon</PlatformBadge>
        <PlatformBadge tone="warning">Beta · 未经 Apple 公证</PlatformBadge>
        <PlatformBadge tone={windows.status === "available" ? "success" : "neutral"}>Windows x64 · Beta</PlatformBadge>
      </div>
    </div>
    <div class="hero-visual" aria-label="从口述到文字的过程示意">
      <div class="visual-orbit" aria-hidden="true"></div>
      <div class="visual-logo"><Logo size={112} compact={false} decorative={false} /></div>
      <div class="visual-path">
        <span>开口说</span><i aria-hidden="true"></i><span>整理成文</span><i aria-hidden="true"></i><span>写入应用</span>
      </div>
      <p>按下快捷键就能开始，不用来回切换窗口。</p>
    </div>
  </div>
</section>
