---
import { sitePath } from "../lib/urls";

interface Props {
  size?: number;
  compact?: boolean;
  decorative?: boolean;
}

const { size = 40, compact = true, decorative = true } = Astro.props;
const file = compact ? "xianyun-c-v2-small.svg" : "xianyun-c-v2-master.svg";
---

<img
  class="brand-logo"
  src={sitePath(`/assets/brand/${file}`)}
  width={size}
  height={size}
  alt={decorative ? "" : "纤云叙 Logo"}
  aria-hidden={decorative ? "true" : undefined}
  decoding="async"
/>
