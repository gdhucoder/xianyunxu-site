---
import Logo from "./Logo.astro";
import { sitePath } from "../lib/urls";

interface Props { currentPath: string }
const { currentPath } = Astro.props;
const links = [
  { href: "/", label: "首页" },
  { href: "/download/", label: "下载" },
  { href: "/install/", label: "安装说明" },
  { href: "/changelog/", label: "更新日志" },
  { href: "/faq/", label: "常见问题" },
];
const isCurrent = (href: string) => currentPath === sitePath(href) || (href !== "/" && currentPath.startsWith(sitePath(href)));
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand-lockup" href={sitePath("/")} aria-label="纤云叙首页">
      <Logo size={38} />
      <span class="brand-name">纤云叙</span>
      <span class="brand-en">XianYun AI Voice Input</span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      {links.map((link) => (
        <a href={sitePath(link.href)} aria-current={isCurrent(link.href) ? "page" : undefined}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>
