---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrimaryButton from "../components/PrimaryButton.astro";
import SecondaryButton from "../components/SecondaryButton.astro";
import { sitePath } from "../lib/urls";
---
<BaseLayout title="页面未找到" description="你访问的纤云叙官网页面不存在。" noindex>
  <section class="page-hero"><div class="shell"><p class="eyebrow">404</p><h1>这个页面找不到了。</h1><p>可能是链接已经变了，也可能是地址输入有误。你可以回到首页，或者直接去下载页面。</p><div class="button-row" style="margin-top: var(--space-6)"><PrimaryButton href={sitePath("/")}>返回首页</PrimaryButton><SecondaryButton href={sitePath("/download/")}>前往下载</SecondaryButton></div></div></section>
</BaseLayout>
