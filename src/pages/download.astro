---
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadCard from "../components/DownloadCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import StatusNotice from "../components/StatusNotice.astro";
import SecondaryButton from "../components/SecondaryButton.astro";
import { downloadManifest, formatBytes, formatPublishedDate } from "../data/downloadManifest";
import { sitePath } from "../lib/urls";
const macos = downloadManifest.platforms["macos-arm64"];
const windows = downloadManifest.platforms["windows-x64"];
const model = downloadManifest.models["sensevoice-small"];
---
<BaseLayout title="下载" description="下载纤云叙 macOS Apple Silicon 与 Windows x64 Beta，查看版本、安装包校验值和签名状态。">
  <header class="page-hero"><div class="shell"><p class="eyebrow">下载中心</p><h1>选择平台之前，先看清版本状态。</h1><p>安装包只通过公开 GitHub Releases 发布。macOS Apple Silicon 与 Windows x64 当前均为 Beta。</p></div></header>
  <section class="section-compact"><div class="shell">
    <div class="metadata-strip" aria-label="当前发布信息">
      <span>渠道：Beta</span><span>版本：v{downloadManifest.version}</span><span>发布日期：{formatPublishedDate(downloadManifest.publishedAt)}</span><span>发布源：GitHub Releases</span>
    </div>
  </div></section>
  <section class="section"><div class="shell">
    <div class="download-grid">
      <DownloadCard platformId="macos-arm64" platform={macos} version={downloadManifest.version} channel={downloadManifest.channel} />
      <DownloadCard platformId="windows-x64" platform={windows} version={downloadManifest.version} channel={downloadManifest.channel} />
    </div>
  </div></section>
  <section class="section section-tinted"><div class="shell">
    <SectionHeading eyebrow="校验信息" title="确认下载文件没有损坏" description="SHA-256 已与公开 Release 资产和实际下载文件核对。校验值不代表平台厂商已经验证该应用。" />
    <div class="grid-2">
      <div><h3 style="margin-bottom: var(--space-3)">macOS Apple Silicon</h3><dl class="checksum"><dt>文件名</dt><dd>{macos.fileName}</dd><dt style="margin-top: var(--space-3)">SHA-256</dt><dd>{macos.sha256}</dd></dl></div>
      <div><h3 style="margin-bottom: var(--space-3)">Windows x64</h3><dl class="checksum"><dt>文件名</dt><dd>{windows.fileName}</dd><dt style="margin-top: var(--space-3)">SHA-256</dt><dd>{windows.sha256}</dd></dl></div>
    </div>
    <div class="grid-2" style="margin-top: var(--space-5)">
      <StatusNotice tone="warning" title="macOS：固定自签名，不等于 Apple 认证">没有 Developer ID 和 notarization，macOS 仍可能阻止首次运行。</StatusNotice>
      <StatusNotice tone="warning" title="Windows：当前未代码签名">SmartScreen 可能提示未知发布者。请只从官方 Release 下载并核对校验值。</StatusNotice>
    </div>
  </div></section>
  <section class="section"><div class="shell grid-2">
    <div>
      <SectionHeading eyebrow="本地模型" title="模型由应用内主动安装" description={`SenseVoiceSmall q8 约 ${formatBytes(model.sizeBytes)}，不包含在 ${formatBytes(macos.sizeBytes)} 的 DMG 中。`} />
      <p class="prose">模型会在用户点击安装后下载、校验并存放到应用数据目录。本地 ASR 不等于云端 LLM 也被关闭。</p>
    </div>
    <div class="button-row">
      <SecondaryButton href={model.platformReleaseUrls["macos-arm64"]} external>macOS 模型说明</SecondaryButton>
      <SecondaryButton href={model.platformReleaseUrls["windows-x64"]} external>Windows 模型说明</SecondaryButton>
      <SecondaryButton href={downloadManifest.releasePageUrl} external>查看 v{downloadManifest.version} Release Notes</SecondaryButton>
    </div>
  </div></section>
  <section class="section-compact"><div class="shell cta-band"><div><h2>第一次安装？</h2><p>macOS 与 Windows 的系统提示不同，请先阅读对应平台说明。</p></div><SecondaryButton href={sitePath("/install/")}>打开安装说明</SecondaryButton></div></section>
</BaseLayout>
