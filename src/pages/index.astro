---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import WorkflowSteps from "../components/WorkflowSteps.astro";
import FeatureCard from "../components/FeatureCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ScreenshotFrame from "../components/ScreenshotFrame.astro";
import PrivacyPathCard from "../components/PrivacyPathCard.astro";
import StatusNotice from "../components/StatusNotice.astro";
import FAQItem from "../components/FAQItem.astro";
import PrimaryButton from "../components/PrimaryButton.astro";
import SecondaryButton from "../components/SecondaryButton.astro";
import PlatformBadge from "../components/PlatformBadge.astro";
import { downloadManifest } from "../data/downloadManifest";
import { sitePath } from "../lib/urls";

const macos = downloadManifest.platforms["macos-arm64"];
---

<BaseLayout>
  <Hero macos={macos} />

  <section class="section-compact" aria-labelledby="workflow-title">
    <div class="shell">
      <SectionHeading eyebrow="使用流程" title="从说话到文字，四步完成" description="同一条状态链路贯穿录音、识别、整理和写入；失败时明确说明文本是否保留。" />
      <h2 id="workflow-title" class="visually-hidden">产品运行过程</h2>
      <WorkflowSteps />
    </div>
  </section>

  <section class="section section-tinted" aria-labelledby="values-title">
    <div class="shell">
      <SectionHeading eyebrow="核心价值" title="少一点切换，多一点专注" description="纤云叙不是聊天机器人，也不是会议录音平台。它只把自然口述可靠地送到当前输入位置。" />
      <h2 id="values-title" class="visually-hidden">三项核心价值</h2>
      <div class="grid-3">
        <FeatureCard index="01" title="随处输入">通过全局快捷键，在常用办公、沟通和写作软件中开始口述。不同应用的兼容性可能存在差异。</FeatureCard>
        <FeatureCard index="02" title="忠实整理">减少明显重复、停顿和口头语，改善标点与句子结构，同时尽量保留原意、事实、数字和表达重点。</FeatureCard>
        <FeatureCard index="03" title="本地可选">可选择本地语音识别模型，并清楚区分本地识别、云端识别和云端文字整理的处理路径。</FeatureCard>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="screenshots-title">
    <div class="shell">
      <SectionHeading eyebrow="真实产品" title="轻量主窗口，低打扰状态浮层" description="官网只展示经过脱敏确认的真实产品截图。当前 V1 尚未获得可公开截图，因此保留明确占位。" />
      <h2 id="screenshots-title" class="visually-hidden">产品截图</h2>
      <div class="grid-2">
        <ScreenshotFrame title="主窗口与运行准备" description="计划展示权限、快捷键、识别方式和整理模式的日常使用入口。" aspect="window" />
        <ScreenshotFrame title="录音状态浮层" description="计划展示底部圆形状态浮层在录音、转写和整理阶段的真实效果。" />
      </div>
    </div>
  </section>

  <section class="section section-tinted" aria-labelledby="paths-title">
    <div class="shell">
      <SectionHeading eyebrow="处理路径" title="本地与云端，边界说清楚" description="“本地识别”只代表 ASR 阶段在本机完成；如果开启云端 LLM，文字仍会发送给所配置的服务。" />
      <h2 id="paths-title" class="visually-hidden">本地与云端处理路径</h2>
      <div class="grid-3">
        <PrivacyPathCard title="本地 ASR · 关闭 LLM" path="语音 → 本机识别 → 基础整理 → 写入" tone="local">识别阶段不需要把语音发送给云端；模型需要由用户主动下载。</PrivacyPathCard>
        <PrivacyPathCard title="本地 ASR · 云端 LLM" path="语音本机识别 → 文字发送至 LLM → 写入" tone="mixed">语音识别在本机完成，但整理文本会按用户配置调用云端服务。</PrivacyPathCard>
        <PrivacyPathCard title="云端 ASR · 可选 LLM" path="语音发送至 ASR → 可选整理 → 写入" tone="cloud">语音会发送给所选 ASR 服务；具体保留政策由对应服务决定。</PrivacyPathCard>
      </div>
      <div style="margin-top: var(--space-5)"><SecondaryButton href={sitePath("/privacy/")}>查看完整隐私说明</SecondaryButton></div>
    </div>
  </section>

  <section class="section" aria-labelledby="platforms-title">
    <div class="shell grid-2">
      <div>
        <SectionHeading eyebrow="平台状态" title="先把 macOS Beta 做清楚" description="当前官网面向 Apple Silicon 测试用户。Windows 仍在开发与人工验收阶段，不提供官网入口。" />
        <h2 id="platforms-title" class="visually-hidden">平台支持状态</h2>
        <div class="hero-badges">
          <PlatformBadge tone="success">macOS Apple Silicon · Beta</PlatformBadge>
          <PlatformBadge>Intel Mac · 暂不支持</PlatformBadge>
          <PlatformBadge>Windows x64 · 开发中</PlatformBadge>
        </div>
      </div>
      <StatusNotice tone="warning" title="当前 Beta 未经 Apple 公证">
        macOS 可能阻止首次打开，需要在“系统设置 → 隐私与安全性”中手动确认。不要关闭 Gatekeeper，也不需要运行不明终端命令。
      </StatusNotice>
    </div>
  </section>

  <section class="section section-tinted" aria-labelledby="privacy-title">
    <div class="shell grid-2">
      <div>
        <SectionHeading eyebrow="隐私与透明性" title="由你决定保存什么、何时联网" description="本地历史提供多种保存模式；模型只在用户明确操作后下载。官网不使用 Cookie 分析、广告或营销追踪。" />
        <h2 id="privacy-title" class="visually-hidden">隐私与透明性</h2>
      </div>
      <div class="prose">
        <p><strong>默认基线：</strong>仅保存统计、保留 30 天、自动删除临时音频。实际设置以应用内显示为准。</p>
        <p><strong>失败透明：</strong>LLM 整理失败时可回退基础文本；写入失败时文本可复制到剪贴板。</p>
        <p><a href={sitePath("/privacy/")}>了解数据路径和待确认事项</a></p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="download-cta-title">
    <div class="shell cta-band">
      <div><h2 id="download-cta-title">准备测试 macOS Beta？</h2><p>先阅读安装说明，确认你理解未公证测试版本的风险。</p></div>
      <div class="button-row">
        <PrimaryButton href={macos.downloadUrl} external>下载 v{downloadManifest.version}</PrimaryButton>
        <SecondaryButton href={sitePath("/install/macos/")}>安装说明</SecondaryButton>
      </div>
    </div>
  </section>

  <section class="section section-tinted" aria-labelledby="faq-title">
    <div class="shell">
      <SectionHeading eyebrow="常见问题" title="安装前，你可能想确认这些" />
      <h2 id="faq-title" class="visually-hidden">常见问题摘要</h2>
      <div class="faq-list">
        <FAQItem question="为什么 macOS 提示无法验证开发者？" open>当前 Beta 没有 Apple Developer ID，也没有经过 Apple 公证。请只从本官网或官方 GitHub Releases 下载，并在系统设置中手动确认。</FAQItem>
        <FAQItem question="本地识别是否代表完全离线？">不一定。本地 ASR 只覆盖识别阶段；开启云端 LLM 后，整理文本仍可能联网。</FAQItem>
        <FAQItem question="支持 Windows 吗？">Windows 版本仍在开发和人工验收中，本官网当前不提供下载。</FAQItem>
        <FAQItem question="输入失败后文字还能找回吗？">LLM 失败时会尽量回退到基础文本；写入失败时会尝试复制到剪贴板。不同失败路径仍应以应用内提示为准。</FAQItem>
      </div>
      <div style="margin-top: var(--space-5)"><SecondaryButton href={sitePath("/faq/")}>查看全部问题</SecondaryButton></div>
    </div>
  </section>
</BaseLayout>
