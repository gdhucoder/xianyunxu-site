---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlatformBadge from "../../components/PlatformBadge.astro";
import SecondaryButton from "../../components/SecondaryButton.astro";
import StatusNotice from "../../components/StatusNotice.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { downloadManifest } from "../../data/downloadManifest";
import { sitePath } from "../../lib/urls";

const macos = downloadManifest.platforms["macos-arm64"];
const windows = downloadManifest.platforms["windows-x64"];
---

<BaseLayout title="安装说明" description="选择 macOS Apple Silicon 或 Windows x64，安全安装纤云叙 Beta。">
  <header class="page-hero"><div class="shell"><p class="eyebrow">安装说明</p><h1>选择你的系统，按步骤安装。</h1><p>Mac 和 Windows 版本目前都是 Beta。选择对应平台后，跟着页面完成下载、安装、权限授权和第一次输入。</p></div></header>
  <section class="section-compact section-tinted"><div class="shell">
    <SectionHeading eyebrow="开始之前" title="先确认三件事" description="花一分钟核对系统、下载来源和校验值，可以避开大多数安装问题。" />
    <div class="grid-3 install-prerequisites">
      <article><span>01</span><h2>选对系统</h2><p>Mac 版只支持 Apple Silicon；Windows 版目前只提供 x64。</p></article>
      <article><span>02</span><h2>只从官网获取</h2><p>下载按钮最终应指向 <strong>gdhucoder/xianyun-releases</strong>，不要使用第三方重打包版本。</p></article>
      <article><span>03</span><h2>核对文件</h2><p>下载页提供文件名和 SHA-256。安装前核对一次，确认文件完整且来源一致。</p></article>
    </div>
  </div></section>
  <section class="section"><div class="shell grid-2">
    <article class="feature-card">
      <PlatformBadge tone="brand">{macos.architecture}</PlatformBadge>
      <h2 style="margin-top: var(--space-5)">macOS Apple Silicon</h2>
      <p>下载 DMG 并拖入“应用程序”，再按页面引导完成第一次打开、麦克风和辅助功能授权。</p>
      <div style="margin-top: var(--space-5)"><SecondaryButton href={sitePath("/install/macos/")}>查看 macOS 步骤</SecondaryButton></div>
    </article>
    <article class="feature-card">
      <PlatformBadge tone="brand">{windows.architecture}</PlatformBadge>
      <h2 style="margin-top: var(--space-5)">Windows x64</h2>
      <p>下载安装程序后，按页面引导完成系统确认、麦克风设置、本地模型安装和第一次输入。</p>
      <div style="margin-top: var(--space-5)"><SecondaryButton href={sitePath("/install/windows/")}>查看 Windows 步骤</SecondaryButton></div>
    </article>
  </div></section>
  <section class="section-compact"><div class="shell"><StatusNotice title="安装遇到问题？">对应平台的安装页列出了常见系统提示和处理方法。无需修改整台电脑的安全设置。</StatusNotice></div></section>
</BaseLayout>
